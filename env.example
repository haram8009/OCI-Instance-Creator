OCI_STACK_ID=ocid1.ormstack.oc1.ap-osaka-1.example
OCI_CONFIG_PROFILE=DEFAULT
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/example/example
DISCORD_USERNAME=OCI Instance Creator
DISCORD_DELIVERY_REQUIRED=true
DISCORD_DELIVERY_ATTEMPTS=5
DISCORD_DELIVERY_RETRY_SECONDS=5
RETRY_INTERVAL_SECONDS=300
MAX_WAIT_SECONDS=1800
MAX_ATTEMPTS=0
LOG_DIR=/app/logs
JOB_LOG_FETCH_ENABLED=true
JOB_LOG_TAIL_CHARS=900

# Optional. Example: --region ap-osaka-1
OCI_CLI_EXTRA_ARGS=
